<% layout('layout') -%>

<%
  const projectTitle = project['title_' + lang] || project.title;
  const projectDescription = project['description_' + lang] || project.description;
  const projectTechnologies = project['technologies_' + lang] || project.technologies;
  const projectFeatures = project['features_' + lang] || project.features;
  const projectDetailedDescription = project['detailedDescription_' + lang] || project.detailedDescription;
%>

<section class="project-detail-section">
    <div class="container">
        <div class="project-header">
            <h1 class="project-title"><%= projectTitle %></h1>
            <div class="project-meta">
                <span class="project-date"><%= new Date(project.createdAt).toLocaleDateString() %></span>
                <% if (project.tags && project.tags.length > 0) { %>
                    <div class="project-tags">
                        <% project.tags.forEach(tag => { %>
                            <span class="tag"><%= tag %></span>
                        <% }); %>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="project-content">
            <div class="project-image">
                <img src="<%= basePath %><%= project.image %>" alt="<%= projectTitle %>" class="project-main-image">
            </div>
            
            <div class="project-description">
                <p><%= projectDescription %></p>
                <div class="project-details">
                    <h3><%= t('project_label_tech') %></h3>
                    <p><%= projectTechnologies %></p>
                    
                    <h3><%= t('project_label_features') %></h3>
                    <p><%= projectFeatures %></p>
                    
                    <h3><%= t('project_label_details') %></h3>
                    <div class="markdown-content">
                        <%= projectDetailedDescription %>
                    </div>
                </div>
                
                <div class="project-links">
                    <% if (project.projectUrl) { %>
                        <a href="<%= project.projectUrl %>" class="btn btn-primary" target="_blank"><%= t('project_btn_view') %></a>
                    <% } %>
                    <% if (project.githubUrl) { %>
                        <a href="<%= project.githubUrl %>" class="btn btn-secondary" target="_blank"><%= t('project_btn_source') %></a>
                    <% } %>
                    <% if (project.reportUrl) { %>
                        <a href="<%= basePath %><%= project.reportUrl %>" class="btn btn-secondary" target="_blank">
                            <i class="fas fa-file-pdf"></i> <%= t('project_btn_report') %>
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>

