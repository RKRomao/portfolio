<% layout('layout') -%>

<section class="upload-section">
    <div class="container">
        <h2 class="section-title">Upload <span class="highlight">Project</span></h2>
        <p class="section-subtitle">Add a new project to your portfolio</p>
        
        <form action="/upload" method="POST" enctype="multipart/form-data" class="upload-form">
            <div class="form-group">
                <label for="title">Project Title</label>
                <input type="text" id="title" name="title" placeholder="Enter project title" required>
            </div>
            
            <div class="form-group">
                <label for="description">Short Description</label>
                <textarea id="description" name="description" rows="4" placeholder="Enter a brief description of the project" required></textarea>
            </div>

            <div class="form-group">
                <label for="detailedDescription">Detailed Description</label>
                <textarea id="detailedDescription" name="detailedDescription" rows="6" placeholder="Enter a detailed description of the project, including:
- Project objectives
- Technologies used
- Main features
- Development process
- Challenges faced and solutions
- Results and impact" required></textarea>
            </div>

            <div class="form-group">
                <label for="technologies">Technologies Used</label>
                <textarea id="technologies" name="technologies" rows="4" placeholder="List the technologies, frameworks, and tools used in the project"></textarea>
            </div>

            <div class="form-group">
                <label for="features">Key Features</label>
                <textarea id="features" name="features" rows="4" placeholder="List the main features of the project"></textarea>
            </div>

            <div class="form-group">
                <label for="tags">Tags (comma separated)</label>
                <input type="text" id="tags" name="tags" placeholder="e.g., Web Design, Development, UI/UX">
            </div>
            
            <div class="form-group file-upload">
                <label for="image">Project Image</label>
                <div class="upload-area" id="dropZone">
                    <i class="fas fa-cloud-upload-alt"></i>
                    <p>Drag & drop your image here or click to browse</p>
                    <input type="file" id="image" name="image" accept="image/*" required>
                    <div id="fileInfo" class="file-info"></div>
                </div>
            </div>
            
            <div class="form-group">
                <label for="projectUrl">Project URL (optional)</label>
                <input type="url" id="projectUrl" name="projectUrl" placeholder="https://example.com">
            </div>
            
            <div class="form-group">
                <label for="githubUrl">GitHub Repository (optional)</label>
                <input type="url" id="githubUrl" name="githubUrl" placeholder="https://github.com/your-repo">
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Upload Project</button>
                <button type="reset" class="btn btn-secondary">Reset Form</button>
            </div>
        </form>
    </div>
</section>

<!-- Preview Section -->
<section class="preview-section">
    <div class="container">
        <h3 class="preview-title">Project Preview</h3>
        <div class="preview-card" id="projectPreview">
            <div class="preview-placeholder">
                <i class="fas fa-image"></i>
                <p>Your project preview will appear here</p>
            </div>
            <div class="preview-content" style="display: none;">
                <div class="preview-image">
                    <img id="imagePreview" src="#" alt="Project Preview">
                </div>
                <div class="preview-details">
                    <h4 id="previewTitle">Project Title</h4>
                    <p id="previewDescription">Project description will appear here. This is a brief overview of what the project is about.</p>
                    <div class="preview-tags" id="previewTags">
                        <span class="tag">Web Design</span>
                        <span class="tag">Development</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('image');
    const fileInfo = document.getElementById('fileInfo');
    const form = document.querySelector('.upload-form');
    
    const previewCard = document.getElementById('projectPreview');
    const previewPlaceholder = previewCard.querySelector('.preview-placeholder');
    const previewContent = previewCard.querySelector('.preview-content');
    const imagePreview = document.getElementById('imagePreview');
    const previewTitle = document.getElementById('previewTitle');
    const previewDescription = document.getElementById('previewDescription');
    const previewTags = document.getElementById('previewTags');
    
    const titleInput = document.getElementById('title');
    const descInput = document.getElementById('description');
    const tagsInput = document.getElementById('tags');

    // Drag and drop events
    ['dragenter', 'dragover'].forEach(eventName => {
        dropZone.addEventListener(eventName, (e) => {
            e.preventDefault();
            dropZone.classList.add('dragover');
        }, false);
    });

    ['dragleave', 'drop'].forEach(eventName => {
        dropZone.addEventListener(eventName, (e) => {
            e.preventDefault();
            dropZone.classList.remove('dragover');
        }, false);
    });

    dropZone.addEventListener('drop', (e) => {
        const dt = e.dataTransfer;
        const files = dt.files;
        if (files.length) {
            fileInput.files = files;
            handleFiles(files[0]);
        }
    }, false);

    fileInput.addEventListener('change', (e) => {
        if (fileInput.files.length) {
            handleFiles(fileInput.files[0]);
        }
    });

    function handleFiles(file) {
        if (!file.type.startsWith('image/')) {
            alert('Por favor, faça upload de um ficheiro de imagem válido (JPEG, PNG, GIF).');
            fileInput.value = '';
            return;
        }
        
        fileInfo.textContent = `Ficheiro selecionado: ${file.name} (${(file.size / 1024).toFixed(1)} KB)`;
        
        const reader = new FileReader();
        reader.onload = (e) => {
            imagePreview.src = e.target.result;
            showPreview();
        };
        reader.readAsDataURL(file);
    }

    function showPreview() {
        previewPlaceholder.style.display = 'none';
        previewContent.style.display = 'flex';
        updatePreviewDetails();
    }

    function updatePreviewDetails() {
        previewTitle.textContent = titleInput.value || 'Título do Projeto';
        previewDescription.textContent = descInput.value || 'A descrição curta do seu projeto aparecerá aqui.';
        
        // Tags
        previewTags.innerHTML = '';
        const tags = tagsInput.value.split(',').map(t => t.trim()).filter(t => t !== '');
        if (tags.length > 0) {
            tags.forEach(tag => {
                const span = document.createElement('span');
                span.className = 'tag';
                span.textContent = tag;
                previewTags.appendChild(span);
            });
        } else {
            const span1 = document.createElement('span');
            span1.className = 'tag';
            span1.textContent = 'Web Design';
            const span2 = document.createElement('span');
            span2.className = 'tag';
            span2.textContent = 'Development';
            previewTags.appendChild(span1);
            previewTags.appendChild(span2);
        }
    }

    // Input listeners
    titleInput.addEventListener('input', updatePreviewDetails);
    descInput.addEventListener('input', updatePreviewDetails);
    tagsInput.addEventListener('input', updatePreviewDetails);

    // Form Reset
    form.addEventListener('reset', () => {
        fileInfo.textContent = '';
        imagePreview.src = '#';
        previewPlaceholder.style.display = 'block';
        previewContent.style.display = 'none';
    });
});
</script>
