<% layout('layout') -%>

<!-- Hero Section -->
<section class="hero contact-hero">
    <div class="container">
        <h1 class="hero-title"><%- t('contact_hero_title') %></h1>
        <p class="hero-subtitle"><%= t('contact_subtitle') %></p>
    </div>
</section>

<!-- Contact Section -->
<section id="contact" class="section">
    <div class="container">
        <div class="contact-grid">
            <!-- Contact Info -->
            <div class="contact-info">
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div class="contact-details">
                        <h3><%= t('contact_email_label') %></h3>
                        <p>koenig.romao@gmail.com</p>
                    </div>
                </div>
                
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="fas fa-phone"></i>
                    </div>
                    <div class="contact-details">
                        <h3><%= t('contact_phone_label') %></h3>
                        <p>+351 933 787 223</p>
                    </div>
                </div>
                
                <div class="contact-card">
                    <div class="contact-icon">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div class="contact-details">
                        <h3><%= t('contact_location_label') %></h3>
                        <p><%= t('location_val') %></p>
                    </div>
                </div>
                
                <div class="social-links">
                    <a href="https://github.com/RKRomao" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                        <i class="fab fa-github"></i>
                    </a>
                    <a href="https://www.linkedin.com/in/ricardo-romão" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <i class="fab fa-linkedin-in"></i>
                    </a>
                    <a href="https://www.instagram.com/killer.rmao" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                        <i class="fab fa-instagram"></i>
                    </a>
                </div>
            </div>
            
            <!-- Contact Form -->
            <div class="contact-form-container">
                <h2 class="section-title"><%= t('contact_form_title') %></h2>
                <form action="<%= linkTo('/contact') %>" method="POST" class="contact-form">
                    <div class="form-group">
                        <input type="text" name="name" placeholder="<%= t('contact_form_name') %>" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <input type="email" name="email" placeholder="<%= t('contact_form_email') %>" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <input type="text" name="subject" placeholder="<%= t('contact_form_subject') %>" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <textarea name="message" placeholder="<%= t('contact_form_message') %>" rows="5" class="form-control" required></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary"><%= t('contact_form_submit') %></button>
                </form>
            </div>
        </div>
    </div>
</section>

