<% layout('layout') -%>

<section id="about" class="about-section">
    <div class="container">
        <div class="about-content">
            <div class="about-image">
                <div class="glow"></div>
                <img src="<%= basePath %>/images/me.png" alt="Ricardo Romão" id="profile-image">
            </div>
            <div class="about-text">
                <h2 class="section-title"><%= t('about_title') %> <span class="highlight"><%= t('about_title_highlight') %></span></h2>
                <div class="section-subtitle"><%= t('about_subtitle') %></div>
                <p><%= t('hero_description') %></p>
                
                <div class="about-details">
                    <div class="detail">
                        <span class="detail-label"><%= t('about_detail_name') %></span>
                        <span class="detail-value">Ricardo Köenig Romão</span>
                    </div>
                    <div class="detail">
                        <span class="detail-label"><%= t('about_detail_email') %></span>
                        <span class="detail-value">koenig.romao@gmail.com</span>
                    </div>
                    <div class="detail">
                        <span class="detail-label"><%= t('about_detail_location') %></span>
                        <span class="detail-value"><%= t('location_val') %></span>
                    </div>
                    <div class="detail">
                        <span class="detail-label"><%= t('about_detail_availability') %></span>
                        <span class="detail-value available"><%= t('about_detail_availability_val') %></span>
                    </div>
                </div>
                
                <a href="<%= linkTo('/contact') %>" class="btn btn-primary"><%= t('about_btn_hire') %></a>
                <a href="<%= basePath %>/files/CV.pdf" class="btn btn-secondary"><%= t('about_btn_cv') %></a>
            </div>
        </div>
        
        <div class="experience-section">
            <h3 class="section-subtitle"><%= t('about_experience_title') %></h3>
